---
---

<section id="home" class="hero">
  <div class="hero-content">
    <div class="hero-text">
      <p class="hero-label">Full Stack Developer / Medellín</p>
      
      <h1 class="hero-name">
        David<br>
        López
      </h1>
      
      <p class="hero-tagline">
        Construyo cosas para internet.
      </p>

      <div class="hero-cta">
        <a href="#projects" class="btn btn-primary">Ver proyectos →</a>
        <a href="#contact" class="btn btn-secondary">Contactar</a>
      </div>

      <div class="hero-stats">
        <div class="stat">
          <span class="stat-number">5+</span>
          <span class="stat-label">años</span>
        </div>
        <div class="stat-divider"></div>
        <div class="stat">
          <span class="stat-number">50+</span>
          <span class="stat-label">proyectos</span>
        </div>
        <div class="stat-divider"></div>
        <div class="stat">
          <span class="stat-number">30+</span>
          <span class="stat-label">clientes</span>
        </div>
      </div>
    </div>

    <div class="hero-visual">
      <div class="code-block">
        <pre><code>const developer = {'{'}
  name: "David López",
  role: "Full Stack Dev",
  status: "disponible"
{'}'};

export default developer;</code></pre>
      </div>
    </div>
  </div>
</section>

<style>
  .hero {
    min-height: 100vh;
    display: flex;
    align-items: center;
    padding-top: 100px;
  }

  .hero-content {
    max-width: 1200px;
    margin: 0 auto;
    padding: 0 5%;
    display: grid;
    grid-template-columns: 1.5fr 1fr;
    gap: 4rem;
    align-items: center;
    width: 100%;
  }

  .hero-text {
    display: flex;
    flex-direction: column;
    gap: 1.5rem;
  }

  .hero-label {
    font-family: var(--font-mono);
    font-size: 0.8rem;
    text-transform: uppercase;
    letter-spacing: 0.15em;
    color: var(--gray);
  }

  .hero-name {
    font-family: var(--font-mono);
    font-size: clamp(4rem, 10vw, 8rem);
    font-weight: 700;
    line-height: 0.9;
    letter-spacing: -0.05em;
    text-transform: uppercase;
  }

  .hero-tagline {
    font-size: 1.25rem;
    color: var(--gray);
    max-width: 400px;
  }

  .hero-cta {
    display: flex;
    gap: 1rem;
    margin-top: 1rem;
  }

  .hero-stats {
    display: flex;
    align-items: center;
    gap: 2rem;
    margin-top: 2rem;
    padding-top: 2rem;
    border-top: var(--border-thin);
  }

  .stat {
    display: flex;
    flex-direction: column;
    gap: 0.25rem;
  }

  .stat-number {
    font-family: var(--font-mono);
    font-size: 2rem;
    font-weight: 700;
    line-height: 1;
  }

  .stat-label {
    font-family: var(--font-mono);
    font-size: 0.7rem;
    text-transform: uppercase;
    letter-spacing: 0.1em;
    color: var(--gray);
  }

  .stat-divider {
    width: 1px;
    height: 40px;
    background: var(--gray);
  }

  .hero-visual {
    display: flex;
    justify-content: center;
  }

  .code-block {
    background: var(--light-gray);
    border: var(--border);
    padding: 1.5rem;
    width: 100%;
    max-width: 400px;
  }

  .code-block pre {
    margin: 0;
  }

  .code-block code {
    font-family: var(--font-mono);
    font-size: 0.85rem;
    line-height: 1.6;
    color: var(--black);
  }

  @media (max-width: 1024px) {
    .hero-content {
      grid-template-columns: 1fr;
      text-align: left;
    }

    .hero-visual {
      order: -1;
    }

    .code-block {
      max-width: 100%;
    }
  }

  @media (max-width: 640px) {
    .hero-name {
      font-size: clamp(3rem, 12vw, 5rem);
    }

    .hero-cta {
      flex-direction: column;
    }

    .hero-stats {
      flex-direction: column;
      align-items: flex-start;
      gap: 1.5rem;
    }

    .stat-divider {
      width: 40px;
      height: 1px;
    }
  }
</style>
